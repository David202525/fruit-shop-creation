[Unit]
Description=Florarium API (FastAPI)
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/florarium
EnvironmentFile=/opt/florarium/.env
ExecStart=/opt/florarium/venv/bin/uvicorn server:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
